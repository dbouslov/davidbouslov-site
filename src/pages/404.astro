---
import Layout from '../layouts/Layout.astro';
---

<Layout title="404 | David Bouslov">
  <main class="relative z-10 min-h-screen flex items-center justify-center px-6">
    <div class="text-center max-w-lg">
      <div class="mb-8">
        <span class="text-8xl md:text-9xl font-bold text-grayblue-800/50">404</span>
      </div>

      <h1 class="text-2xl md:text-3xl font-semibold text-grayblue-100 mb-4">
        Page not found
      </h1>
      <p class="text-grayblue-400 mb-8">
        The page you're looking for doesn't exist or has been moved.
      </p>

      <a
        href="/"
        class="inline-block px-6 py-3 rounded-lg bg-grayblue-700/50 text-grayblue-100 hover:bg-grayblue-600/50 transition-colors font-medium"
      >
        Go home
      </a>
    </div>
  </main>
</Layout>
