---
import Layout from '../layouts/Layout.astro';
import ParticleBackground from '../components/ParticleBackground.astro';
import Footer from '../components/Footer.astro';

const papers = [
  {
    title: "An Early Pipeline Framework for Assessing Vendor AI Solutions to Support Return on Investment",
    venue: "npj Digital Medicine",
    year: "2025",
    url: "https://pubmed.ncbi.nlm.nih.gov/40523928/",
  },
  {
    title: "\u03B2 Cell G\u03B1s Signaling is Critical for Physiological and Pharmacological Enhancement of Insulin Secretion",
    venue: "Journal of Clinical Investigation",
    year: "2025",
    url: "https://pubmed.ncbi.nlm.nih.gov/40526441/",
  },
  {
    title: "Glucagon Promotes Net Hepatic Glycogen Repletion Following Meal Ingestion",
    venue: "Diabetes",
    year: "2024",
    url: null,
  },
];

const textbookChapters = [
  {
    title: "Artificial Intelligence in Surgery: Clinical and Ethical Considerations",
    venue: "Schwartz's Principles of Surgery",
    url: null,
  },
];

const abstracts = [
  {
    title: "AI Governance at Hackensack Meridian Health: A Practical Framework for Strategic and Safe Implementation",
    venue: "Medical Student Research Day 2025",
  },
  {
    title: "Artificial Intelligence in Surgery: Clinical and Ethical Considerations",
    venue: "Medical Student Research Day 2025",
  },
  {
    title: "Building Trust in AI: A Community Perspective on the Inclusion of AI in Healthcare",
    venue: "Medical Student Research Day 2025",
  },
  {
    title: "Glucagon and Insulin Cross Talk Regulates Hepatic Glycogen Metabolism",
    venue: "American Diabetes Association",
  },
  {
    title: "Leveraging Glucagon Activity to Target Hepatic Steatosis, Fibrosis, and Inflammation",
    venue: "American Diabetes Association",
  },
];
---

<Layout title="David Bouslov">
  <ParticleBackground />

  <!-- Navigation -->
  <nav class="fixed top-0 left-0 right-0 z-50 px-6 py-4 backdrop-blur-md bg-grayblue-950/80 border-b border-white/[0.05]">
    <div class="max-w-3xl mx-auto flex items-center justify-between">
      <a href="#" class="text-grayblue-100 hover:text-white transition-colors font-semibold tracking-tight">
        DB
      </a>

      <!-- Desktop Nav -->
      <div class="hidden md:flex items-center gap-6 text-sm">
        <a href="#education" class="text-grayblue-400 hover:text-grayblue-100 transition-colors">Education</a>
        <a href="#research" class="text-grayblue-400 hover:text-grayblue-100 transition-colors">Research</a>
        <a href="#publications" class="text-grayblue-400 hover:text-grayblue-100 transition-colors">Publications</a>
        <a href="#contact" class="text-grayblue-400 hover:text-grayblue-100 transition-colors">Contact</a>
      </div>

      <!-- Mobile Menu Button -->
      <button id="mobile-menu-btn" class="md:hidden p-2 text-grayblue-400 hover:text-grayblue-100 transition-colors" aria-label="Open menu">
        <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"></path>
        </svg>
      </button>
    </div>

    <!-- Mobile Menu -->
    <div id="mobile-menu" class="md:hidden hidden absolute top-full left-0 right-0 bg-grayblue-950/95 backdrop-blur-md border-b border-white/[0.05] px-6 py-4">
      <div class="flex flex-col gap-4">
        <a href="#education" class="text-grayblue-300 hover:text-grayblue-100 transition-colors py-2">Education</a>
        <a href="#research" class="text-grayblue-300 hover:text-grayblue-100 transition-colors py-2">Research</a>
        <a href="#publications" class="text-grayblue-300 hover:text-grayblue-100 transition-colors py-2">Publications</a>
        <a href="#contact" class="text-grayblue-300 hover:text-grayblue-100 transition-colors py-2">Contact</a>
      </div>
    </div>
  </nav>

  <main class="relative z-10">
    <!-- Hero Section -->
    <section class="pt-32 pb-16 px-6">
      <div class="max-w-3xl mx-auto">
        <h1 class="text-4xl md:text-5xl font-bold tracking-tight">
          <span class="text-grayblue-100">David Bouslov</span>
        </h1>

        <p class="mt-4 text-lg text-grayblue-400">
          M.D. Candidate <span class="text-grayblue-600">&middot;</span> Class of 2027
        </p>

        <p class="mt-3 text-grayblue-500 max-w-xl leading-relaxed">
          Medical student at Hackensack Meridian School of Medicine with research interests
          in health economics, artificial intelligence in healthcare, and surgical outcomes.
        </p>
      </div>
    </section>

    <!-- Education Section -->
    <section id="education" class="py-16 px-6">
      <div class="max-w-3xl mx-auto">
        <h2 data-animate class="text-2xl font-bold text-grayblue-100 mb-8">Education</h2>

        <div class="space-y-6">
          <div data-animate data-animate-delay="1" class="p-5 rounded-lg bg-white/[0.02] border border-white/[0.06]">
            <div class="flex flex-col sm:flex-row sm:items-start sm:justify-between gap-1">
              <div>
                <h3 class="text-grayblue-100 font-semibold">Hackensack Meridian School of Medicine</h3>
                <p class="text-sm text-grayblue-400">Doctor of Medicine</p>
              </div>
              <span class="text-sm text-grayblue-500 sm:text-right shrink-0">2023 &ndash; 2027</span>
            </div>
          </div>

          <div data-animate data-animate-delay="2" class="p-5 rounded-lg bg-white/[0.02] border border-white/[0.06]">
            <div class="flex flex-col sm:flex-row sm:items-start sm:justify-between gap-1">
              <div>
                <h3 class="text-grayblue-100 font-semibold">University of North Carolina at Chapel Hill</h3>
                <p class="text-sm text-grayblue-400">B.S. Biology, Chemistry Minor</p>
                <p class="text-sm text-grayblue-500">Phi Beta Kappa</p>
              </div>
              <span class="text-sm text-grayblue-500 sm:text-right shrink-0">2019 &ndash; 2023</span>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- Research Section -->
    <section id="research" class="py-16 px-6 bg-white/[0.01]">
      <div class="max-w-3xl mx-auto">
        <h2 data-animate class="text-2xl font-bold text-grayblue-100 mb-8">Research Interests</h2>

        <div data-animate data-animate-delay="1" class="grid sm:grid-cols-2 gap-4">
          <div class="p-4 rounded-lg bg-white/[0.02] border border-white/[0.06]">
            <h3 class="text-grayblue-200 font-medium mb-1">Health Economics</h3>
            <p class="text-sm text-grayblue-400">Cost-effectiveness analysis, Markov modeling, economic evaluation of surgical and pharmacological interventions</p>
          </div>
          <div class="p-4 rounded-lg bg-white/[0.02] border border-white/[0.06]">
            <h3 class="text-grayblue-200 font-medium mb-1">AI in Healthcare</h3>
            <p class="text-sm text-grayblue-400">Clinical AI governance, vendor assessment frameworks, responsible implementation of AI in hospital systems</p>
          </div>
          <div class="p-4 rounded-lg bg-white/[0.02] border border-white/[0.06]">
            <h3 class="text-grayblue-200 font-medium mb-1">Surgical Outcomes</h3>
            <p class="text-sm text-grayblue-400">Predictive modeling for surgical outcomes, quality improvement, NSQIP-based research</p>
          </div>
          <div class="p-4 rounded-lg bg-white/[0.02] border border-white/[0.06]">
            <h3 class="text-grayblue-200 font-medium mb-1">Endocrine Physiology</h3>
            <p class="text-sm text-grayblue-400">Glucagon signaling, hepatic glycogen metabolism, beta cell physiology and insulin secretion</p>
          </div>
        </div>
      </div>
    </section>

    <!-- Publications Section -->
    <section id="publications" class="py-16 px-6">
      <div class="max-w-3xl mx-auto">
        <h2 data-animate class="text-2xl font-bold text-grayblue-100 mb-8">Publications</h2>

        <!-- Papers -->
        <div data-animate data-animate-delay="1" class="mb-10">
          <h3 class="text-sm font-semibold text-grayblue-400 uppercase tracking-wider mb-4">Peer-Reviewed Papers</h3>
          <div class="space-y-3">
            {papers.map((pub) => (
              pub.url ? (
                <a href={pub.url} target="_blank" rel="noopener noreferrer" class="block p-4 rounded-lg bg-white/[0.02] border border-white/[0.06] hover:bg-white/[0.04] hover:border-grayblue-600/40 transition-all group">
                  <h4 class="text-sm font-medium text-grayblue-100 leading-relaxed group-hover:text-white transition-colors">{pub.title}</h4>
                  <p class="mt-1.5 text-xs text-grayblue-400 flex items-center gap-2">
                    <span class="italic text-grayblue-300">{pub.venue}</span>
                    <span class="text-grayblue-600">&middot;</span>
                    <span>{pub.year}</span>
                    <svg class="w-3 h-3 opacity-0 group-hover:opacity-100 transition-opacity ml-auto" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14"></path>
                    </svg>
                  </p>
                </a>
              ) : (
                <div class="p-4 rounded-lg bg-white/[0.02] border border-white/[0.06]">
                  <h4 class="text-sm font-medium text-grayblue-100 leading-relaxed">{pub.title}</h4>
                  <p class="mt-1.5 text-xs text-grayblue-400">
                    <span class="italic text-grayblue-300">{pub.venue}</span>
                    <span class="text-grayblue-600"> &middot; </span>
                    <span>{pub.year}</span>
                  </p>
                </div>
              )
            ))}
          </div>
        </div>

        <!-- Textbook Chapters -->
        <div data-animate data-animate-delay="2" class="mb-10">
          <h3 class="text-sm font-semibold text-grayblue-400 uppercase tracking-wider mb-4">Textbook Chapters</h3>
          <div class="space-y-3">
            {textbookChapters.map((pub) => (
              <div class="p-4 rounded-lg bg-white/[0.02] border border-white/[0.06]">
                <h4 class="text-sm font-medium text-grayblue-100 leading-relaxed">{pub.title}</h4>
                <p class="mt-1.5 text-xs text-grayblue-400">
                  <span class="italic text-grayblue-300">{pub.venue}</span>
                </p>
              </div>
            ))}
          </div>
        </div>

        <!-- Abstracts -->
        <div data-animate data-animate-delay="3">
          <h3 class="text-sm font-semibold text-grayblue-400 uppercase tracking-wider mb-4">Abstracts &amp; Presentations</h3>
          <div class="space-y-3">
            {abstracts.map((pub) => (
              <div class="p-4 rounded-lg bg-white/[0.02] border border-white/[0.06]">
                <h4 class="text-sm font-medium text-grayblue-100 leading-relaxed">{pub.title}</h4>
                <p class="mt-1.5 text-xs text-grayblue-400">
                  <span class="italic text-grayblue-300">{pub.venue}</span>
                </p>
              </div>
            ))}
          </div>
        </div>
      </div>
    </section>

    <Footer />
  </main>
</Layout>
